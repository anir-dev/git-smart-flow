{
  "name": "git-smart-flow",
  "version": "0.1.0",
  "description": "Interactive CLI to manage Git workflows guided, safe and smart",
  "type": "module",
  "keywords": [
    "git",
    "cli",
    "conventional-commits",
    "developer-tools",
    "open-source"
  ],
  "homepage": "https://github.com/YOUR_USERNAME/git-smart-flow",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/git-smart-flow.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/cli.js",
  "bin": {
    "git-smart-flow": "./bin/git-smart-flow.js",
    "gsf": "./bin/gsf.js",
    "gsfc": "./bin/gsfc.js",
    "gsfm": "./bin/gsfm.js",
    "gsfp": "./bin/gsfp.js",
    "gsfpr": "./bin/gsfpr.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "npx tsx --test tests/**/*.test.ts",
    "smoke": "bash scripts/smoke-test.sh",
    "prepare-release": "tsx scripts/prepare-release.ts",
    "release": "release-it",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "asciichart": "^1.5.25",
    "boxen": "^8.0.0",
    "chalk": "4.1.2",
    "clipboardy": "^4.0.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "figlet": "^1.8.0",
    "globby": "^14.0.0",
    "ink": "^5.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "js-yaml": "^4.1.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.0",
    "@types/asciichart": "^1.5.3",
    "@types/figlet": "^1.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "pkg": "^5.8.1",
    "release-it": "^17.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-macos-x64",
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "downloads"
  }
}
